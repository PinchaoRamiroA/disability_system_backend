APP_NAME=disability_system
APP_ENV=development
APP_VERSION=1.0.0
APP_PORT=8080

SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# ===========================
# Opción 1: Docker local
# ===========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=password
DB_NAME=disability_system_db
DB_SSLMODE=disable

# ===========================
# Opción 2: Supabase (usar DATABASE_URL completo, comentar arriba)
# ===========================
# DATABASE_URL=postgresql://postgres.udzyfgsrcaygmulrfffw:[PASSWORD]@aws-1-us-west-1.pooler.supabase.com:6543/postgres

DB_POOL_MODE=transaction
DB_PREPARE_CACHE=true

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5

JWT_SECRET=supersecretkey
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRY=168h

## CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true

## Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=disability-bucket
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com