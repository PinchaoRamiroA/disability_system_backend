{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/api/v1/auth/login": {
            "post": {
                "description": "Autentica un usuario y devuelve tokens de acceso",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Iniciar sesión",
                "parameters": [
                    {
                        "description": "Credenciales de login",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_modules_auth_dto.LoginRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/disability_system_backend_internal_modules_auth_dto.LoginResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/refresh": {
            "post": {
                "description": "Obtiene nuevos tokens usando un refresh token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Renovar token",
                "parameters": [
                    {
                        "description": "Refresh token",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_modules_auth_dto.RefreshTokenRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/disability_system_backend_internal_modules_auth_dto.TokenResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/auth/register": {
            "post": {
                "description": "Crea un nuevo usuario en el sistema",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Registrar usuario",
                "parameters": [
                    {
                        "description": "Datos del usuario",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_modules_auth_dto.RegisterRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/disability_system_backend_internal_modules_auth_dto.UserResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    }
                }
            }
        },
        "/incapacidades/transcripciones/pendientes": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Lista las incapacidades con transcripción pendiente",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "incapacidades"
                ],
                "summary": "Listar transcripciones pendientes",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Estado de transcripción (pendiente, en_proceso, completado, vencida)",
                        "name": "estado",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 1,
                        "description": "Número de página",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 20,
                        "description": "Límite de resultados",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/incapacidades/{id}/transcribir": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Registra la transcripción de una incapacidad ante la EPS/ARL",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "incapacidades"
                ],
                "summary": "Registrar transcripción EPS/ARL",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de la incapacidad",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Datos de transcripción",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_modules_incapacidades_dto.TranscribirIncapacidadRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "transcripción registrada exitosamente",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    }
                }
            }
        },
        "/incapacidades/{id}/transcripcion": {
            "patch": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Marca el estado de transcripción de una incapacidad como 'en_proceso'",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "incapacidades"
                ],
                "summary": "Marcar transcripción en proceso",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de la incapacidad",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Estado de transcripción",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_modules_incapacidades_dto.MarcarTranscripcionRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "estado actualizado",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/disability_system_backend_internal_shared_response.Response"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "disability_system_backend_internal_modules_auth_dto.LoginRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "minLength": 6
                }
            }
        },
        "disability_system_backend_internal_modules_auth_dto.LoginResponse": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "expires_in": {
                    "type": "integer"
                },
                "refresh_token": {
                    "type": "string"
                },
                "token_type": {
                    "type": "string"
                },
                "user": {
                    "$ref": "#/definitions/disability_system_backend_internal_modules_auth_dto.UserResponse"
                }
            }
        },
        "disability_system_backend_internal_modules_auth_dto.RefreshTokenRequest": {
            "type": "object",
            "required": [
                "refresh_token"
            ],
            "properties": {
                "refresh_token": {
                    "type": "string"
                }
            }
        },
        "disability_system_backend_internal_modules_auth_dto.RegisterRequest": {
            "type": "object",
            "required": [
                "email",
                "nombre",
                "numero_documento",
                "password"
            ],
            "properties": {
                "direccion": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "nombre": {
                    "type": "string",
                    "maxLength": 150,
                    "minLength": 2
                },
                "numero_celular": {
                    "type": "string"
                },
                "numero_documento": {
                    "type": "string",
                    "minLength": 5
                },
                "password": {
                    "type": "string",
                    "minLength": 6
                }
            }
        },
        "disability_system_backend_internal_modules_auth_dto.RoleResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "integer"
                },
                "nombre": {
                    "type": "string"
                },
                "permisos": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "disability_system_backend_internal_modules_auth_dto.TokenResponse": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "expires_in": {
                    "type": "integer"
                },
                "refresh_token": {
                    "type": "string"
                },
                "token_type": {
                    "type": "string"
                }
            }
        },
        "disability_system_backend_internal_modules_auth_dto.UserResponse": {
            "type": "object",
            "properties": {
                "correo": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "direccion": {
                    "type": "string"
                },
                "estado": {
                    "type": "boolean"
                },
                "id": {
                    "type": "integer"
                },
                "nombre": {
                    "type": "string"
                },
                "numero_celular": {
                    "type": "string"
                },
                "numero_documento": {
                    "type": "string"
                },
                "rol": {
                    "$ref": "#/definitions/disability_system_backend_internal_modules_auth_dto.RoleResponse"
                }
            }
        },
        "disability_system_backend_internal_modules_incapacidades_dto.MarcarTranscripcionRequest": {
            "type": "object",
            "required": [
                "estado"
            ],
            "properties": {
                "estado": {
                    "type": "string",
                    "enum": [
                        "en_proceso",
                        "completado"
                    ]
                }
            }
        },
        "disability_system_backend_internal_modules_incapacidades_dto.TranscribirIncapacidadRequest": {
            "type": "object",
            "properties": {
                "observaciones_transcripcion": {
                    "type": "string"
                }
            }
        },
        "disability_system_backend_internal_shared_response.ErrorInfo": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "details": {}
            }
        },
        "disability_system_backend_internal_shared_response.Response": {
            "type": "object",
            "properties": {
                "data": {},
                "error": {
                    "$ref": "#/definitions/disability_system_backend_internal_shared_response.ErrorInfo"
                },
                "message": {
                    "type": "string"
                },
                "success": {
                    "type": "boolean"
                }
            }
        }
    }
}